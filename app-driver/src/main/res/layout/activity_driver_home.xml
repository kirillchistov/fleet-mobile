<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_fleet_screen"
    android:padding="@dimen/fleet_screen_padding">

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/topSystemInsetGuideline"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_begin="@dimen/fleet_system_top_inset" />

    <TextView
        android:id="@+id/contentTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:gravity="center"
        android:text="@string/driver_top_vehicle_name"
        android:textAppearance="@style/TextAppearance.Fleet.Subtitle"
        android:textColor="@color/fleet_fg"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/topSystemInsetGuideline" />

    <TextView
        android:id="@+id/plateChip"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:background="@drawable/bg_status_chip"
        android:paddingHorizontal="12dp"
        android:paddingVertical="4dp"
        android:text="@string/driver_top_plate"
        android:textAppearance="@style/TextAppearance.Fleet.Caption"
        android:textColor="@color/fleet_fg"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/contentTitle" />

    <ScrollView
        android:id="@+id/contentScroll"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="10dp"
        app:layout_constraintBottom_toTopOf="@id/bottomNavBar"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/plateChip">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <LinearLayout
                android:id="@+id/sectionVehicles"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/driver_range_km"
                            android:textAppearance="@style/TextAppearance.Fleet.ScreenTitle"
                            android:textColor="@color/fleet_fg" />

                        <ProgressBar
                            style="?android:attr/progressBarStyleHorizontal"
                            android:layout_width="110dp"
                            android:layout_height="8dp"
                            android:layout_marginTop="8dp"
                            android:max="100"
                            android:progress="75"
                            android:progressTint="@color/fleet_primary" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:text="@string/driver_battery_percent"
                            android:textAppearance="@style/TextAppearance.Fleet.Subtitle" />
                    </LinearLayout>

                    <ImageView
                        android:layout_width="190dp"
                        android:layout_height="130dp"
                        android:src="@drawable/ic_vehicle_sova" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:gravity="center"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="♨"
                        android:textColor="#EF4444"
                        android:textSize="40sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:text="⚠"
                        android:textColor="#FACC15"
                        android:textSize="40sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:text="ABS"
                        android:textColor="#FACC15"
                        android:textStyle="bold"
                        android:textSize="28sp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:gravity="center"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:orientation="vertical">

                        <ImageView
                            android:layout_width="46dp"
                            android:layout_height="46dp"
                            android:background="@drawable/bg_fleet_card"
                            android:padding="10dp"
                            android:src="@android:drawable/ic_lock_lock"
                            app:tint="@color/fleet_primary" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:text="@string/driver_doors_title"
                            android:textAppearance="@style/TextAppearance.Fleet.Subtitle"
                            android:textColor="@color/fleet_fg" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/driver_doors_state"
                            android:textAppearance="@style/TextAppearance.Fleet.Caption" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:orientation="vertical">

                        <ImageView
                            android:layout_width="46dp"
                            android:layout_height="46dp"
                            android:background="@drawable/bg_fleet_card"
                            android:padding="10dp"
                            android:src="@android:drawable/ic_menu_rotate"
                            app:tint="@color/fleet_muted_fg" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:text="@string/driver_warmup_title"
                            android:textAppearance="@style/TextAppearance.Fleet.Subtitle"
                            android:textColor="@color/fleet_fg" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/driver_warmup_state"
                            android:textAppearance="@style/TextAppearance.Fleet.Caption" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:orientation="vertical">

                        <ImageView
                            android:layout_width="46dp"
                            android:layout_height="46dp"
                            android:background="@drawable/bg_fleet_card"
                            android:padding="10dp"
                            android:src="@android:drawable/ic_lock_silent_mode_off"
                            app:tint="@color/fleet_muted_fg" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:text="@string/driver_signal_title"
                            android:textAppearance="@style/TextAppearance.Fleet.Subtitle"
                            android:textColor="@color/fleet_fg" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/driver_signal_state"
                            android:textAppearance="@style/TextAppearance.Fleet.Caption" />
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:background="@drawable/bg_fleet_card"
                    android:orientation="horizontal"
                    android:padding="14dp">

                    <ImageView
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:src="@android:drawable/ic_dialog_alert"
                        app:tint="@android:color/white" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="10dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/driver_maintenance_title"
                            android:textAppearance="@style/TextAppearance.Fleet.Subtitle"
                            android:textColor="@color/fleet_fg" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="@string/driver_maintenance_subtitle"
                            android:textAppearance="@style/TextAppearance.Fleet.Caption" />
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_marginEnd="8dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <LinearLayout
                            android:id="@+id/openLogbookTile"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_fleet_card"
                            android:clickable="true"
                            android:focusable="true"
                            android:orientation="vertical"
                            android:padding="14dp">

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="@string/driver_logbook_title"
                                android:textAppearance="@style/TextAppearance.Fleet.Subtitle"
                                android:textColor="@color/fleet_fg" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="6dp"
                                android:background="@drawable/bg_status_chip"
                                android:paddingHorizontal="8dp"
                                android:paddingVertical="2dp"
                                android:text="2"
                                android:textColor="@color/fleet_fg" />
                        </LinearLayout>

                        <LinearLayout
                            android:id="@+id/openVehicleInfoTile"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:background="@drawable/bg_fleet_card"
                            android:clickable="true"
                            android:focusable="true"
                            android:orientation="vertical"
                            android:padding="14dp">

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="@string/driver_vehicle_info_tile_title"
                                android:textAppearance="@style/TextAppearance.Fleet.Subtitle"
                                android:textColor="@color/fleet_fg" />
                        </LinearLayout>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:background="@drawable/bg_fleet_card"
                        android:orientation="vertical"
                        android:padding="14dp">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/driver_map_title"
                            android:textAppearance="@style/TextAppearance.Fleet.Subtitle"
                            android:textColor="@color/fleet_fg" />

                        <com.google.android.material.button.MaterialButton
                            style="@style/Widget.Fleet.OutlinedIconButton"
                            android:layout_width="wrap_content"
                            android:layout_height="36dp"
                            android:layout_marginTop="56dp"
                            android:text="@string/driver_find_vehicle" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/sectionCharging"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_fleet_card"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/driver_charging_title"
                        android:textAppearance="@style/TextAppearance.Fleet.Subtitle"
                        android:textColor="@color/fleet_fg" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="@string/driver_charging_subtitle"
                        android:textAppearance="@style/TextAppearance.Fleet.Caption" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/startChargingButton"
                        style="@style/Widget.Fleet.PrimaryButton"
                        android:layout_width="match_parent"
                        android:layout_height="44dp"
                        android:layout_marginTop="12dp"
                        android:text="@string/driver_action_start_charge" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/sectionHelp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_fleet_card"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/driver_help_title"
                        android:textAppearance="@style/TextAppearance.Fleet.Subtitle"
                        android:textColor="@color/fleet_fg" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="@string/driver_help_subtitle"
                        android:textAppearance="@style/TextAppearance.Fleet.Caption" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/openChatButton"
                        style="@style/Widget.Fleet.PrimaryButton"
                        android:layout_width="match_parent"
                        android:layout_height="44dp"
                        android:layout_marginTop="12dp"
                        android:text="@string/driver_action_open_chat" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </ScrollView>

    <LinearLayout
        android:id="@+id/bottomNavBar"
        android:layout_width="0dp"
        android:layout_height="72dp"
        android:layout_marginTop="10dp"
        android:background="@drawable/bg_fleet_card"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingHorizontal="10dp"
        android:weightSum="4"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <LinearLayout
            android:id="@+id/navHome"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:id="@+id/navHomeIcon"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:contentDescription="@string/bottom_nav_home"
                android:src="@drawable/ic_nav_home"
                app:tint="@color/fleet_muted_fg" />

            <TextView
                android:id="@+id/navHomeLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="@string/bottom_nav_home"
                android:textAppearance="@style/TextAppearance.Fleet.Caption" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/navVehicles"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:id="@+id/navVehiclesIcon"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:contentDescription="@string/bottom_nav_vehicles"
                android:src="@drawable/ic_nav_vehicle"
                app:tint="@color/fleet_primary" />

            <TextView
                android:id="@+id/navVehiclesLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="@string/bottom_nav_vehicles"
                android:textAppearance="@style/TextAppearance.Fleet.Caption" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/navCharging"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:id="@+id/navChargingIcon"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:contentDescription="@string/bottom_nav_driver_charging"
                android:src="@drawable/ic_nav_charging"
                app:tint="@color/fleet_muted_fg" />

            <TextView
                android:id="@+id/navChargingLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="@string/bottom_nav_driver_charging"
                android:textAppearance="@style/TextAppearance.Fleet.Caption" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/navHelp"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:id="@+id/navHelpIcon"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:contentDescription="@string/bottom_nav_driver_help"
                android:src="@drawable/ic_nav_help"
                app:tint="@color/fleet_muted_fg" />

            <TextView
                android:id="@+id/navHelpLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="@string/bottom_nav_driver_help"
                android:textAppearance="@style/TextAppearance.Fleet.Caption" />
        </LinearLayout>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
