<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_fleet_screen"
    android:orientation="vertical"
    android:padding="@dimen/fleet_screen_padding">

    <Space
        android:layout_width="match_parent"
        android:layout_height="@dimen/fleet_system_top_inset" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="@string/driver_new_record_title"
            android:textAppearance="@style/TextAppearance.Fleet.Title"
            android:textColor="@color/fleet_fg" />

        <ImageButton
            android:id="@+id/closeButton"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@android:color/transparent"
            android:contentDescription="@string/cancel"
            android:src="@android:drawable/ic_menu_close_clear_cancel"
            android:tint="@color/fleet_muted_fg" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="@string/driver_damage_type_label"
                android:textAppearance="@style/TextAppearance.Fleet.Caption" />

            <EditText
                android:id="@+id/typeInput"
                android:layout_width="match_parent"
                android:layout_height="46dp"
                android:layout_marginTop="4dp"
                android:background="@drawable/bg_fleet_card"
                android:hint="@string/driver_damage_type_hint"
                android:paddingHorizontal="14dp"
                android:textColor="@color/fleet_fg"
                android:textColorHint="@color/fleet_muted_fg" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="@string/driver_damage_summary_label"
                android:textAppearance="@style/TextAppearance.Fleet.Caption" />

            <EditText
                android:id="@+id/summaryInput"
                android:layout_width="match_parent"
                android:layout_height="96dp"
                android:layout_marginTop="4dp"
                android:background="@drawable/bg_fleet_card"
                android:gravity="top|start"
                android:hint="@string/driver_damage_summary_hint"
                android:padding="14dp"
                android:textColor="@color/fleet_fg"
                android:textColorHint="@color/fleet_muted_fg" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="90dp"
                    android:layout_height="90dp"
                    android:background="@drawable/bg_fleet_card"
                    android:scaleType="centerCrop"
                    android:src="@drawable/ic_vehicle_sova" />

                <LinearLayout
                    android:id="@+id/addPhotoButton"
                    android:layout_width="90dp"
                    android:layout_height="90dp"
                    android:layout_marginStart="10dp"
                    android:background="@drawable/bg_fleet_card"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:orientation="vertical">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@android:drawable/ic_menu_camera"
                        app:tint="@color/fleet_fg" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="@string/driver_add_photo"
                        android:textAppearance="@style/TextAppearance.Fleet.Caption"
                        android:textColor="@color/fleet_fg" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/driver_service_request"
                    android:textAppearance="@style/TextAppearance.Fleet.Subtitle"
                    android:textColor="@color/fleet_fg" />

                <Switch
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />
            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/addRecordButton"
                style="@style/Widget.Fleet.PrimaryButton"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="20dp"
                android:text="@string/driver_add_record" />
        </LinearLayout>
    </ScrollView>

    <LinearLayout
        android:id="@+id/bottomNavBar"
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:layout_marginTop="10dp"
        android:background="@drawable/bg_fleet_card"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingHorizontal="10dp"
        android:weightSum="3">

        <LinearLayout
            android:id="@+id/navVehicles"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:id="@+id/navVehiclesIcon"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:contentDescription="@string/bottom_nav_vehicles"
                android:src="@drawable/ic_nav_vehicle"
                app:tint="@color/fleet_muted_fg" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="@string/bottom_nav_vehicles"
                android:textAppearance="@style/TextAppearance.Fleet.Caption" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/navCharging"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:id="@+id/navChargingIcon"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:contentDescription="@string/bottom_nav_driver_charging"
                android:src="@drawable/ic_nav_charging"
                app:tint="@color/fleet_muted_fg" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="@string/bottom_nav_driver_charging"
                android:textAppearance="@style/TextAppearance.Fleet.Caption" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/navHelp"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:id="@+id/navHelpIcon"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:contentDescription="@string/bottom_nav_driver_help"
                android:src="@drawable/ic_nav_help"
                app:tint="@color/fleet_primary" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="@string/bottom_nav_driver_help"
                android:textAppearance="@style/TextAppearance.Fleet.Caption" />
        </LinearLayout>
    </LinearLayout>

</LinearLayout>
