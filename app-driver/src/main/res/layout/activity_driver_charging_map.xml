<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_fleet_screen"
    android:orientation="vertical"
    android:padding="@dimen/fleet_screen_padding">

    <Space
        android:layout_width="match_parent"
        android:layout_height="@dimen/fleet_system_top_inset" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="42dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">
        <ImageButton
            android:id="@+id/backButton"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:background="@android:color/transparent"
            android:contentDescription="@string/back"
            android:src="@drawable/ic_back_native"
            android:tint="@color/fleet_fg" />
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:text="@string/driver_charging_map_title"
            android:textAppearance="@style/TextAppearance.Fleet.ScreenTitle" />
        <com.google.android.material.button.MaterialButton
            android:id="@+id/filterButton"
            style="@style/Widget.Fleet.PrimaryButton"
            android:layout_width="wrap_content"
            android:layout_height="38dp"
            android:text="@string/driver_open_filter" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="12dp"
        android:background="@drawable/bg_fleet_card"
        android:gravity="center"
        android:orientation="vertical">
        <ImageView
            android:layout_width="68dp"
            android:layout_height="68dp"
            android:src="@drawable/ic_nav_charging" />
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="Карта зарядных станций"
            android:textAppearance="@style/TextAppearance.Fleet.Subtitle"
            android:textColor="@color/fleet_fg" />
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="МСК-Юг #12 • 120 кВт • 2 свободно"
            android:textAppearance="@style/TextAppearance.Fleet.Caption" />
    </LinearLayout>

    <include layout="@layout/view_driver_bottom_nav" />
</LinearLayout>
