<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_fleet_screen"
    android:orientation="vertical"
    android:padding="@dimen/fleet_screen_padding">

    <Space
        android:layout_width="match_parent"
        android:layout_height="@dimen/fleet_system_top_inset" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <ImageButton
            android:id="@+id/backButton"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@android:color/transparent"
            android:contentDescription="@string/back"
            android:src="@android:drawable/ic_media_previous"
            android:tint="@color/fleet_fg" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:text="@string/driver_sts_title"
            android:textAppearance="@style/TextAppearance.Fleet.Title"
            android:textColor="@color/fleet_fg" />
    </LinearLayout>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:background="@drawable/bg_fleet_card"
        android:padding="14dp"
        android:text="@string/driver_sts_content"
        android:textAppearance="@style/TextAppearance.Fleet.Subtitle"
        android:textColor="@color/fleet_fg" />

</LinearLayout>
