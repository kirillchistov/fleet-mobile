<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_fleet_screen"
    android:orientation="vertical"
    android:padding="@dimen/fleet_screen_padding">

    <Space
        android:layout_width="match_parent"
        android:layout_height="@dimen/fleet_system_top_inset" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <ImageButton
            android:id="@+id/backButton"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@android:color/transparent"
            android:contentDescription="@string/back"
            android:src="@drawable/ic_back_native"
            android:tint="@color/fleet_fg" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:text="@string/driver_journal_title"
            android:textAppearance="@style/TextAppearance.Fleet.ScreenTitle"
            android:textColor="@color/fleet_fg" />

        <ImageButton
            android:id="@+id/addButton"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@android:color/transparent"
            android:contentDescription="@string/driver_journal_add"
            android:src="@android:drawable/ic_input_add"
            android:tint="@color/fleet_fg" />
    </LinearLayout>

    <EditText
        android:id="@+id/searchInput"
        android:layout_width="match_parent"
        android:layout_height="46dp"
        android:layout_marginTop="10dp"
        android:background="@drawable/bg_fleet_card"
        android:hint="@string/driver_journal_search_hint"
        android:inputType="text"
        android:paddingHorizontal="14dp"
        android:textColor="@color/fleet_fg"
        android:textColorHint="@color/fleet_muted_fg" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="10dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <LinearLayout
                android:id="@+id/journalCard1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_fleet_card"
                android:orientation="vertical"
                android:padding="14dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/driver_journal_item_1"
                    android:textAppearance="@style/TextAppearance.Fleet.Subtitle"
                    android:textColor="@color/fleet_fg" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="@string/driver_journal_item_type_1"
                    android:textAppearance="@style/TextAppearance.Fleet.Caption" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="@string/driver_journal_item_meta_1"
                    android:textAppearance="@style/TextAppearance.Fleet.Caption" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/openDetails1"
                    style="@style/Widget.Fleet.PrimaryButton"
                    android:layout_width="match_parent"
                    android:layout_height="46dp"
                    android:layout_marginTop="10dp"
                    android:text="@string/driver_journal_open_details" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/journalCard2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_fleet_card"
                android:orientation="vertical"
                android:padding="14dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/driver_journal_item_2"
                    android:textAppearance="@style/TextAppearance.Fleet.Subtitle"
                    android:textColor="@color/fleet_fg" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="@string/driver_journal_item_type_2"
                    android:textAppearance="@style/TextAppearance.Fleet.Caption" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="@string/driver_journal_item_meta_2"
                    android:textAppearance="@style/TextAppearance.Fleet.Caption" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/openDetails2"
                    style="@style/Widget.Fleet.PrimaryButton"
                    android:layout_width="match_parent"
                    android:layout_height="46dp"
                    android:layout_marginTop="10dp"
                    android:text="@string/driver_journal_open_details" />
            </LinearLayout>
        </LinearLayout>
    </ScrollView>

    <include layout="@layout/view_driver_bottom_nav" />

</LinearLayout>
