<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_fleet_screen"
    android:orientation="vertical"
    android:padding="@dimen/fleet_screen_padding">

    <Space
        android:layout_width="match_parent"
        android:layout_height="@dimen/fleet_system_top_inset" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <ImageButton
            android:id="@+id/backButton"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@android:color/transparent"
            android:contentDescription="@string/back"
            android:src="@android:drawable/ic_media_previous"
            android:tint="@color/fleet_fg" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:text="@string/driver_available_cars_title"
            android:textAppearance="@style/TextAppearance.Fleet.Title"
            android:textColor="@color/fleet_fg" />
    </LinearLayout>

    <EditText
        android:id="@+id/searchInput"
        android:layout_width="match_parent"
        android:layout_height="46dp"
        android:layout_marginTop="10dp"
        android:background="@drawable/bg_fleet_card"
        android:hint="@string/driver_available_cars_search_hint"
        android:inputType="text"
        android:paddingHorizontal="14dp"
        android:textColor="@color/fleet_fg"
        android:textColorHint="@color/fleet_muted_fg" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="10dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <LinearLayout
                android:id="@+id/cardSova25"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_fleet_card"
                android:clickable="true"
                android:focusable="true"
                android:orientation="vertical"
                android:padding="14dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Sova 25 • X349MT116"
                    android:textAppearance="@style/TextAppearance.Fleet.Subtitle"
                    android:textColor="@color/fleet_fg" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="@string/driver_available_car_meta_1"
                    android:textAppearance="@style/TextAppearance.Fleet.Caption" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/cardSova35"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_fleet_card"
                android:clickable="true"
                android:focusable="true"
                android:orientation="vertical"
                android:padding="14dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Sova 35 • К728РХ116"
                    android:textAppearance="@style/TextAppearance.Fleet.Subtitle"
                    android:textColor="@color/fleet_fg" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="@string/driver_available_car_meta_2"
                    android:textAppearance="@style/TextAppearance.Fleet.Caption" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/cardEvmPro"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_fleet_card"
                android:clickable="true"
                android:focusable="true"
                android:orientation="vertical"
                android:padding="14dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="EVM Pro • А920НК116"
                    android:textAppearance="@style/TextAppearance.Fleet.Subtitle"
                    android:textColor="@color/fleet_fg" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="@string/driver_available_car_meta_3"
                    android:textAppearance="@style/TextAppearance.Fleet.Caption" />
            </LinearLayout>
        </LinearLayout>
    </ScrollView>

    <LinearLayout
        android:id="@+id/bottomNavBar"
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:layout_marginTop="10dp"
        android:background="@drawable/bg_fleet_card"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingHorizontal="10dp"
        android:weightSum="3">

        <LinearLayout
            android:id="@+id/navVehicles"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:id="@+id/navVehiclesIcon"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:contentDescription="@string/bottom_nav_vehicles"
                android:src="@drawable/ic_nav_vehicle"
                app:tint="@color/fleet_primary" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="@string/bottom_nav_vehicles"
                android:textAppearance="@style/TextAppearance.Fleet.Caption" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/navCharging"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:id="@+id/navChargingIcon"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:contentDescription="@string/bottom_nav_driver_charging"
                android:src="@drawable/ic_nav_charging"
                app:tint="@color/fleet_muted_fg" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="@string/bottom_nav_driver_charging"
                android:textAppearance="@style/TextAppearance.Fleet.Caption" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/navHelp"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:id="@+id/navHelpIcon"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:contentDescription="@string/bottom_nav_driver_help"
                android:src="@drawable/ic_nav_help"
                app:tint="@color/fleet_muted_fg" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="@string/bottom_nav_driver_help"
                android:textAppearance="@style/TextAppearance.Fleet.Caption" />
        </LinearLayout>
    </LinearLayout>

</LinearLayout>
