<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    android:background="@drawable/bg_fleet_card"
    android:orientation="vertical"
    android:padding="12dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <ImageView
            android:layout_width="84dp"
            android:layout_height="56dp"
            android:background="@drawable/bg_fleet_screen"
            android:padding="6dp"
            android:src="@android:drawable/ic_menu_gallery"
            android:scaleType="centerCrop" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/vehicleTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:maxLines="1"
                android:ellipsize="end"
                android:textAppearance="@style/TextAppearance.Fleet.Subtitle" />

            <TextView
                android:id="@+id/vehicleMeta"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:textAppearance="@style/TextAppearance.Fleet.Caption" />

            <TextView
                android:id="@+id/vehicleStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:textAppearance="@style/TextAppearance.Fleet.Caption" />

            <TextView
                android:id="@+id/vehicleFleet"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:textAppearance="@style/TextAppearance.Fleet.Caption" />
        </LinearLayout>

        <ImageButton
            android:id="@+id/btnEdit"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@drawable/bg_fleet_card"
            android:contentDescription="@string/edit_entity"
            android:src="@android:drawable/ic_menu_edit"
            android:tint="@color/fleet_primary" />
    </LinearLayout>

    <TextView
        android:id="@+id/btnDelete"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:background="@drawable/bg_delete_button"
        android:gravity="center"
        android:paddingVertical="10dp"
        android:text="@string/delete_entity"
        android:textColor="#E74C5B"
        android:textStyle="bold" />

</LinearLayout>
