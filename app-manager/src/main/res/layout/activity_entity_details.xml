<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_fleet_screen"
    android:padding="@dimen/fleet_screen_padding">

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/topSystemInsetGuideline"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_begin="@dimen/fleet_system_top_inset" />

    <ImageView
        android:id="@+id/logoSignTop"
        android:layout_width="@dimen/fleet_logo_sign_width"
        android:layout_height="@dimen/fleet_logo_sign_height"
        android:contentDescription="@string/fleet_logo_sign_content_description"
        android:src="@drawable/ic_logo_sign"
        app:layout_constraintBottom_toBottomOf="@id/topSystemInsetGuideline"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.5" />

    <LinearLayout
        android:id="@+id/contentCard"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/fleet_spacing_lg"
        android:background="@drawable/bg_fleet_card"
        android:orientation="vertical"
        android:padding="@dimen/fleet_card_padding"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/topSystemInsetGuideline">

        <TextView
            android:id="@+id/detailsTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textAppearance="@style/TextAppearance.Fleet.Title" />

        <TextView
            android:id="@+id/detailsBody"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/fleet_spacing_sm"
            android:textAppearance="@style/TextAppearance.Fleet.Subtitle" />

        <ImageView
            android:id="@+id/vehicleImage"
            android:layout_width="180dp"
            android:layout_height="108dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="@dimen/fleet_spacing_lg"
            android:src="@android:drawable/ic_menu_compass"
            android:tint="@color/fleet_fg" />

        <TextView
            android:id="@+id/detailsMenuTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/fleet_spacing_lg"
            android:text="@string/vehicle_docs_and_specs"
            android:textAppearance="@style/TextAppearance.Fleet.Subtitle" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/relationPrimary"
            style="@style/Widget.Fleet.PrimaryButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/fleet_spacing_lg"
            android:text="@string/open_related" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/relationSecondary"
            style="@style/Widget.Fleet.PrimaryButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/fleet_spacing_sm"
            android:text="@string/open_related" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
